\usepackage{etoolbox}  % Necesario para \collectbox

% Definir el entorno 'scale' usando collectbox para evitar el problema con parámetros
\newlength{\envwidth}

\newenvironment{scale}[1]
{%
    \setlength{\envwidth}{\linewidth/\real{#1}} % Calcular el ancho en función del factor de escala
    \begin{collectbox} % Iniciar la captura del contenido del entorno
        \scalebox{#1}{\begin{minipage}{\envwidth}} % Escalar y establecer el ancho de minipage
}%
{%
        \end{minipage}%
    \end{collectbox} % Terminar la captura y mostrar el contenido
}
