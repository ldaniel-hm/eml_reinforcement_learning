  \setbeamercolor{enumerate item}{fg=\exerciseblockcolour}
  \setbeamercolor{enumerate subitem}{fg=\exerciseblockcolour}
  \setbeamercolor{enumerate subsubitem}{fg=\exerciseblockcolour}
} 

