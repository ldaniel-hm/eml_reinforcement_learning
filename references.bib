@article{Russo2018TS,
	author = {{Daniel J. Russo} and {Benjamin Van Roy} and {Abbas Kazerouni} and {Ian Osband} and {Zheng Wen}},
	doi = {10.1561/2200000070},
	issn = {1935-8237},
	journal = {Foundations and Trends{\textregistered} in Machine Learning},
	note = {El muestreo de Thompson es un algoritmo para problemas de decisi{\'o}n en l{\'\i}nea donde las acciones se toman de manera secuencial, equilibrando entre explotar lo que se sabe para maximizar el rendimiento inmediato e invertir en acumular nueva informaci{\'o}n que pueda mejorar el rendimiento futuro. El algoritmo aborda una amplia gama de problemas de manera computacionalmente eficiente, por lo que goza de un uso extendido. Este tutorial cubre el algoritmo y sus aplicaciones, ilustrando conceptos a trav{\'e}s de diversos ejemplos, incluyendo problemas de bandido de Bernoulli, problemas de caminos m{\'a}s cortos, recomendaci{\'o}n de productos, surtido, aprendizaje activo con redes neuronales y aprendizaje por refuerzo en procesos de decisi{\'o}n de Markov. La mayor{\'\i}a de estos problemas implican estructuras de informaci{\'o}n complejas, donde la informaci{\'o}n revelada al tomar una acci{\'o}n informa las creencias sobre otras acciones. Tambi{\'e}n discutiremos cu{\'a}ndo y por qu{\'e} el muestreo de Thompson es o no efectivo, as{\'\i} como sus relaciones con algoritmos alternativos.},
	number = {1},
	pages = {1-96},
	title = {A Tutorial on Thompson Sampling},
	url = {http://dx.doi.org/10.1561/2200000070},
	volume = {11},
	year = {2018},
	bdsk-url-1 = {http://dx.doi.org/10.1561/2200000070}}



