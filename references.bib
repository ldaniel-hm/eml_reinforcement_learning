@article{Auer2002,
	author = {{Peter Auer} and {Nicol{\`{o}} Cesa{-}Bianchi} and {Paul Fischer}},
	doi = {10.1023/A:1013689704352},
	journal = {Machine Learning},
	note = {Las pol{\'\i}ticas de aprendizaje por refuerzo enfrentan el dilema de exploraci{\'o}n versus explotaci{\'o}n, es decir, la b{\'u}squeda de un equilibrio entre explorar el entorno para encontrar acciones rentables y tomar la mejor acci{\'o}n emp{\'\i}ricamente con la mayor frecuencia posible. Una medida popular del {\'e}xito de una pol{\'\i}tica para abordar este dilema es el arrepentimiento, es decir, la p{\'e}rdida debida al hecho de que no se sigue la pol{\'\i}tica globalmente {\'o}ptima en todo momento. Uno de los ejemplos m{\'a}s simples del dilema exploraci{\'o}n/explotaci{\'o}n es el problema de los bandidos con m{\'u}ltiples brazos. Lai y Robbins fueron los primeros en demostrar que el arrepentimiento por este problema debe crecer al menos de forma logar{\'\i}tmica en el n{\'u}mero de jugadas. Desde entonces, Lai y Robbins y muchos otros han ideado pol{\'\i}ticas que logran asint{\'o}ticamente este arrepentimiento. En este trabajo mostramos que el arrepentimiento logar{\'\i}tmico {\'o}ptimo tambi{\'e}n se puede lograr de manera uniforme a lo largo del tiempo, con pol{\'\i}ticas simples y eficientes, y para todas las distribuciones de recompensa con apoyo acotado.},
	number = {2-3},
	pages = {235--256},
	title = {Finite-time Analysis of the Multiarmed Bandit Problem},
	url = {https://doi.org/10.1023/A:1013689704352},
	volume = {47},
	year = {2002},
	bdsk-url-1 = {https://doi.org/10.1023/A:1013689704352}}



