	doi = {10.1090/S0002-9904-1952-09620-8},
	journal = {Bulletin of the American Mathematical Society},
	note = {En este art{\'\i}culo seminal, Robbins introduce el "problema del bandido de m{\'u}ltiples brazos", un problema clave en la toma de decisiones secuencial. El art{\'\i}culo aborda c{\'o}mo asignar recursos entre opciones competidoras (brazos) para maximizar la recompensa esperada a lo largo del tiempo, equilibrando la exploraci{\'o}n (probar diferentes opciones) con la explotaci{\'o}n (elegir la opci{\'o}n con el mayor rendimiento conocido). Este trabajo asent{\'o} las bases para el aprendizaje por refuerzo moderno y tiene aplicaciones en campos que van desde la econom{\'\i}a hasta la inteligencia artificial.},
	number = {5},
	pages = {527--535},
	publisher = {American Mathematical Society},
	title = {Some Aspects of the Sequential Design of Experiments},
